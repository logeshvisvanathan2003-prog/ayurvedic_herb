# Copy to .env — defaults already match blockchain/network's Docker-free setup.
CHANNEL_NAME=ayurveda-channel
CHAINCODE_NAME=traceability
MSP_ID=Org1MSP
PEER_ENDPOINT=localhost:7051
PEER_HOST_ALIAS=peer0.org1.ayurveda.com
PORT=4000

# Only needed if your crypto-config lives somewhere other than
# blockchain/network/crypto-config (the default location scripts 01-06 use):
# CRYPTO_PATH=/absolute/path/to/blockchain/network/crypto-config/peerOrganizations/org1.ayurveda.com
